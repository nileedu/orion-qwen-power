# Orion Qwen Power root configuration.
# Copy to .env only if you want to override defaults.

HUB_PORT=3800
HUB_HOST=127.0.0.1
HUB_API_KEY=orion-proxy-key
QWENPROXY_URL=http://localhost:3802
QWENPROXY_KEY=orion-proxy-key
DEFAULT_MODEL=qwen/3.7-max

# qwenproxy
QWENPROXY_PORT=3802
QWEN_HEADLESS=true
QWEN_BROWSER=chromium
QWEN_USER_DATA_DIR=./qwen_profiles
